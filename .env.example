# =============================================================================
# ApplyNest — environment template (safe to commit; contains no secrets)
# =============================================================================
# Copy the API block into:     apps/api/.env
# Copy the web block only if:  you build the SPA against a remote API origin
#
# Never commit apps/api/.env, apps/web/.env, or any file with real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# API — copy everything below into apps/api/.env
# -----------------------------------------------------------------------------

NODE_ENV=development
PORT=4000

# Browser origin allowed to call the API (Vite dev server by default)
CORS_ORIGIN=http://localhost:5173

# Required — MongoDB connection URI (local mongod, Docker, or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/applynest

# Required — secret used to sign JWTs; use a long random string in production
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters

# Optional — access token lifetime in seconds (default: 604800 = 7 days)
JWT_EXPIRES_SECONDS=604800

# Optional — OpenAI for job-description parsing and resume-bullet suggestions.
# If unset, the API uses deterministic fallbacks (no external AI calls).
# OPENAI_API_KEY=

# Optional — model name when OPENAI_API_KEY is set (default in code: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Web — only for production builds when API is on another host (optional)
# Copy into apps/web/.env if needed
# -----------------------------------------------------------------------------

# In development, leave unset: Vite proxies /api to http://localhost:4000.
# In production, set to the public API origin (no trailing slash), e.g.:
# VITE_API_URL=https://api.example.com
