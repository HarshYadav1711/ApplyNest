# ApplyNest — copy values into `backend/.env` for local development.
# Never commit real secrets.

# --- MongoDB ---
MONGODB_URI=mongodb://127.0.0.1:27017/applynest

# --- Auth (use a long random string in production) ---
JWT_SECRET=change-me-to-a-long-random-secret
# Access token lifetime in seconds (default 7 days)
JWT_EXPIRES_SECONDS=604800

# --- API server ---
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- AI (optional) ---
# When unset, job parsing and resume bullets use deterministic fallbacks.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Frontend (optional) ---
# Leave unset to use the Vite dev proxy to the API on port 4000.
# For production builds, set to your API origin, e.g. https://api.example.com
# VITE_API_URL=
