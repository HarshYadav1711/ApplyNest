# Copy to apps/api/.env (never commit real secrets).

PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MongoDB (required)
MONGODB_URI=mongodb://127.0.0.1:27017/applynest

# JWT (required — use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_SECONDS=604800

# AI job-description parsing (optional — deterministic fallback when unset)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional: production SPA → set API origin if not using same host
# VITE_API_URL=https://api.example.com
